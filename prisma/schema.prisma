generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model Audit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessName String
  city         String  @default("")
  sector       String  @default("")
  activityType String

  scoreGlobal   Int @default(0)
  scoreSocial   Int @default(0)
  scoreWeb      Int @default(0)
  scoreGBP      Int @default(0)
  scoreFunnel   Int @default(0)
  scoreBranding Int @default(0)

  scoreGlobalRaw Int @default(0)
  
  sectorTemplateId String?
  sectorPercentile Int?

  lostClientsJSON Json?
  competitorsJSON Json?

  fullName String?
  email    String?
  phone    String?

  answersJSON Json

  isUnlocked Boolean @default(false)
  pdfUrl     String?

  @@index([email])
  @@index([createdAt])
  @@index([isUnlocked])
  @@index([sector])
  @@index([sectorTemplateId])
}
// ─── AdminSession ─────────────────────────────────────────────────────────────

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([token])
  @@index([expiresAt])
}